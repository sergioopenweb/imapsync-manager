SECRET_KEY=your-secret-key-generate-with-openssl-rand-hex-32

DB_HOST=localhost
DB_USER=imapsync_user
DB_PASSWORD=your-db-password
DB_NAME=imapsync_manager
DB_POOL_SIZE=10

LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

MAX_LOGS_POR_CONTA=10
SYNC_MAX_WORKERS=3
SYNC_CONTA_TIMEOUT_SEC=1800
SYNC_MAX_ERROS_CONSECUTIVOS=50
SYNC_IMAP_MAX_RECONNECTS=3
SYNC_ORPHAN_LOG_SEC=480
# Grava Message-IDs no histórico a cada N cópias (evita perder marcação se a sync cair)
SYNC_HISTORICO_FLUSH_EVERY_N=50
EMAILS_POR_PAGINA=50

# Flask / Servidor
FLASK_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=5001

# Fuso horário de exibição (UTC offset em horas inteiras, ex: -3 para Brasília)
APP_TIMEZONE_OFFSET=-3

# Retenção de histórico (dias)
HISTORICO_FILTRO_RETENTION_DAYS=90
HISTORICO_EMAILS_RETENTION_DAYS=90

# Dashboard — janelas de tempo
DASHBOARD_ERROS_HORAS=24
DASHBOARD_ATIVIDADE_DIAS=6

# Truncamento de mensagens salvas / exibidas
LOG_MENSAGEM_DB_MAX_LEN=1000
SYNC_STATUS_MESSAGE_MAX_LEN=200
API_SYNC_STATUS_MESSAGE_MAX_LEN=500

# Limites de listagem (UI / SQL)
LOGS_UI_LIMIT=50
LOGS_CONTA_DETALHE_LIMIT=20
HISTORICO_EMAILS_DEFAULT_LIMIT=200
FILTRO_ULTIMOS_EMAILS_LIMIT=30

# IMAP
DEFAULT_IMAP_SSL_PORT=993
IMAP_SOCKET_TIMEOUT=30
IMAP_MESSAGE_ID_BATCH_SIZE=100

# Segurança
MIN_PASSWORD_LENGTH=6
API_KEY_BYTES=32

# SMTP
SMTP_CONNECT_TIMEOUT=15

# Alertas por email (opcional — deixe em branco para desativar)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=ImapSync Alerts <alerts@example.com>
ALERT_FALHAS_CONSECUTIVAS=3
